# Variabile de mediu pentru plata Stripe (NU urca fisierul .env real pe GitHub!)
# Copiaza acest fisier in ".env" si completeaza cu cheile tale.
# Cheile de TEST incep cu pk_test_ / sk_test_. Cele LIVE cu pk_live_ / sk_live_.

# COMUTATOR PRINCIPAL pentru plata.
#   false = aplicatia este GRATUITA (plata oprita), indiferent de chei. <-- starea curenta
#   true  = plata ACTIVA, dar functioneaza doar daca sunt completate si cele 2 chei de mai jos.
PAYMENTS_ENABLED=false

# Cheia secreta (DOAR pe server, niciodata in pagina / in browser)
STRIPE_SECRET_KEY=sk_test_inlocuieste_aici

# Cheia publica (poate aparea in pagina)
STRIPE_PUBLISHABLE_KEY=pk_test_inlocuieste_aici

# Pret per pachet de 3 bilete (in lei) si cate bilete sunt gratis
PRICE_PER_PACK_LEI=5
FREE_TICKETS=3
TICKETS_PER_PACK=3

# Adresa publica a aplicatiei (pentru redirect dupa plata).
# Local: http://localhost:8000 ; pe Render: https://simulatorloto.onrender.com
PUBLIC_BASE_URL=http://localhost:8000
